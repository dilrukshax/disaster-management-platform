generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("REQUEST_DATABASE_URL")
}

enum RequestCategory {
  water
  food
  medicine
  shelter
  rescue
  transport
  other
}

enum Urgency {
  low
  medium
  high
}

enum RequestStatus {
  pending
  matched
  assigned
  in_progress
  completed
  cancelled
}

model ReliefRequest {
  id          String          @id @default(uuid())
  requesterId String
  category    RequestCategory
  description String
  urgency     Urgency
  district    String
  city        String
  addressLine String
  latitude    Float?
  longitude   Float?
  peopleCount Int
  status      RequestStatus   @default(pending)
  lastStatusUpdatedBy String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}
