generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("VOLUNTEER_DATABASE_URL")
}

enum VolunteerAvailability {
  available
  busy
  offline
}

enum VolunteerVerificationStatus {
  pending
  approved
  rejected
}

enum ResourceAvailability {
  available
  reserved
  unavailable
}

enum AssignmentStatus {
  assigned
  in_progress
  completed
}

enum MissionApplicationStatus {
  pending
  accepted
  rejected
}

model Volunteer {
  id                 String                @id @default(uuid())
  userId             String                @unique
  skillSet           String[]
  district           String
  city               String
  availabilityStatus VolunteerAvailability @default(available)
  verificationStatus VolunteerVerificationStatus @default(pending)
  verificationNotes  String?
  verifiedBy         String?
  verifiedAt         DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  assignments Assignment[]
  applications MissionApplication[]
}

model Resource {
  id                 String               @id @default(uuid())
  ownerId            String
  category           String
  quantity           Int
  district           String
  city               String
  availabilityStatus ResourceAvailability @default(available)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  assignments Assignment[]
}

model Assignment {
  id         String           @id @default(uuid())
  requestId  String
  volunteerId String?
  resourceId String?
  applicationId String?
  assignedBy String
  status     AssignmentStatus @default(assigned)
  assignedAt DateTime         @default(now())

  volunteer Volunteer? @relation(fields: [volunteerId], references: [id])
  resource  Resource?  @relation(fields: [resourceId], references: [id])
  application MissionApplication? @relation(fields: [applicationId], references: [id])
}

model MissionApplication {
  id         String                   @id @default(uuid())
  requestId  String
  volunteerId String
  message    String?
  status     MissionApplicationStatus @default(pending)
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt

  volunteer Volunteer @relation(fields: [volunteerId], references: [id])
  assignments Assignment[]

  @@index([requestId])
  @@index([status])
  @@unique([requestId, volunteerId])
}
