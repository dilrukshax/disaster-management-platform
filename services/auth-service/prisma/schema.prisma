generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("AUTH_DATABASE_URL")
}

enum Role {
  requester
  volunteer
  coordinator
  admin
}

model User {
  id           String   @id @default(uuid())
  fullName     String
  email        String   @unique
  phone        String
  passwordHash String
  role         Role     @default(requester)
  district     String
  city         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
