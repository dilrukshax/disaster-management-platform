{
  "name": "relieflink-platform",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev:web": "pnpm --filter @relieflink/web dev",
    "dev:gateway": "pnpm --filter @relieflink/api-gateway dev",
    "dev:auth": "pnpm --filter @relieflink/auth-service dev",
    "dev": "concurrently -k \"pnpm dev:auth\" \"pnpm dev:gateway\" \"pnpm dev:web\"",
    "build": "pnpm --filter @relieflink/auth-service build && pnpm --filter @relieflink/api-gateway build && pnpm --filter @relieflink/web build",
    "test:auth-unit": "pnpm --filter @relieflink/auth-service test:unit",
    "test:api-smoke": "node scripts/api-smoke.mjs",
    "test:ui-smoke": "node scripts/ui-smoke.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
